# Next.js (raiz) — copiar para .env.local
# LMS_API_TOKEN deve coincidir com o backend. JWT / DB / CORS: backend/.env.example

# --- Core (local) ---
NEXT_PUBLIC_USE_JAVA_API=true
LMS_API_URL=http://localhost:8080
LMS_API_TOKEN=
AUTH_SECRET=
ALLOW_DEMO_LOGIN=true
# Legado: alias de ALLOW_DEMO_LOGIN (só fora de produção)
AUTH_DEMO_ENABLED=
# Override da senha mock (default no código: demo1234)
DEMO_LOGIN_PASSWORD=

# --- Gates / demo UI ---
# Só staging/demo controlada — não setar em produção pública
NEXT_PUBLIC_SHOW_MOCK_MODULES=

# --- Microsoft Entra / URL do app ---
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AUTH_ALLOWED_EMAIL_DOMAIN=
NEXT_PUBLIC_APP_URL=
# Preenchidos pela plataforma (opcionais)
RAILWAY_PUBLIC_DOMAIN=
VERCEL_URL=

# --- Outros ---
YOUTUBE_API_KEY=
# Host(s) do bucket/CDN para CSP media-src (opcional; default já permite https:)
NEXT_PUBLIC_MEDIA_HOST=
# Legado — preferir LMS_API_URL
NEXT_PUBLIC_API_URL=
