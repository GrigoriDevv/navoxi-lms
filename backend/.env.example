# Spring (backend/) — exportar no shell ou tool de deploy
# Profile local: SPRING_PROFILES_ACTIVE=local  ou  -Dspring-boot.run.profiles=local

# --- Servidor / token ---
PORT=8080
LMS_API_TOKEN=
LMS_JWT_SECRET=
LMS_JWT_TTL_SECONDS=604800
CORS_ORIGINS=http://localhost:3000

# --- Auth / seed / rate limit ---
LMS_BLOCK_DEMO_SEED_LOGINS=
LMS_JIT_PROVISIONING=
LMS_JIT_DEFAULT_UNIT=matriz
LMS_ALLOWED_EMAIL_DOMAINS=
LMS_BOOTSTRAP_ADMIN_EMAILS=
LMS_LOGIN_RATE_LIMIT_ENABLED=
LMS_LOGIN_RATE_LIMIT_MAX=
LMS_LOGIN_RATE_LIMIT_WINDOW_SECONDS=
LMS_SEED_ENABLED=
LMS_SEED_PASSWORD=

# --- DB (profile prod / Postgres) ---
# Nome real em application.yml (não DATABASE_URL)
JDBC_DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=

# --- Object storage (MP4) — S3-compatible ---
# Sem LMS_S3_ENABLED=true o endpoint POST /api/v1/media/videos responde 503
LMS_S3_ENABLED=false
LMS_S3_ENDPOINT=
LMS_S3_REGION=us-east-1
LMS_S3_BUCKET=
LMS_S3_ACCESS_KEY=
LMS_S3_SECRET_KEY=
# URL pública/CDN (sem barra final). Se vazio, usa URL signed GET
LMS_S3_PUBLIC_BASE_URL=
LMS_S3_MAX_FILE_BYTES=104857600
LMS_S3_PRESIGN_TTL_SECONDS=3600
LMS_S3_MAX_REQUEST_BYTES=110100480
